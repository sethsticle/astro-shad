{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    ".astro/types.d.ts",
    "src/**/*",
    "./worker-configuration.d.ts"
  ],
  "exclude": [
    "dist",
    "spike-consumer",
    "node_modules"
  ]
}