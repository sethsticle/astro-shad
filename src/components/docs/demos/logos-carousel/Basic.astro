---
import LogosCarousel from '../../../astro-shad/LogosCarousel.astro';
---

<!-- each direct child is one logo group -->
<LogosCarousel interval={2200} class="max-w-2xl text-muted-foreground">
  <div>
    <span class="text-lg font-semibold">Astro</span>
    <span class="text-lg font-semibold">Tailwind</span>
    <span class="text-lg font-semibold">shadcn</span>
  </div>
  <div>
    <span class="text-lg font-semibold">Vanilla JS</span>
    <span class="text-lg font-semibold">Zero React</span>
    <span class="text-lg font-semibold">Tokens</span>
  </div>
</LogosCarousel>
