---
/**
 * Checkbox.astro -- astro-shad bare checkbox primitive. Converted from
 * shadcn ui/checkbox.tsx (base-ui Checkbox.Root/Indicator). Rung 1: a
 * real `<input type="checkbox">` with `appearance-none` styling plus a
 * sibling check-mark SVG shown via the `peer`/`peer-checked:` CSS
 * selector -- base-ui's Root/Indicator split existed to sync a "checked"
 * data-attribute to a rendered child; the browser already tracks
 * `:checked`, so that's the whole mechanism, zero JS.
 *
 * This is the unlabelled building block -- `FormField.astro`'s
 * `type="checkbox"` renders its own inline markup (it needs the
 * label/description/error wiring); reach for this one when composing a
 * checkbox outside FormField (e.g. a filter list, a sidebar toggle row).
 *
 *   <label class="flex items-center gap-2"><Checkbox name="tos" /> I agree</label>
 *   <Checkbox checked disabled />
 */
import { cn } from '../../lib/utils';

interface Props {
  checked?: boolean;
  class?: string;
  [key: string]: unknown;
}

const { checked, class: className, ...rest } = Astro.props;
---

<span class="relative inline-flex size-4 shrink-0">
  <input
    type="checkbox"
    data-slot="checkbox"
    checked={checked}
    class={cn(
      'peer size-4 shrink-0 cursor-pointer appearance-none rounded-[4px] border border-input bg-transparent transition-colors ' +
        'checked:border-primary checked:bg-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring ' +
        'disabled:cursor-not-allowed disabled:opacity-50 aria-invalid:border-destructive',
      className
    )}
    {...rest}
  />
  <svg
    class="pointer-events-none absolute inset-0 m-auto hidden size-3 text-primary-foreground peer-checked:block"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="3"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="M20 6 9 17l-5-5" />
  </svg>
</span>
