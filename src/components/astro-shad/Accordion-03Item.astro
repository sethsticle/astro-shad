---
import { cn } from "../../lib/utils";

interface Props {
  title: string;
  /** Render this item expanded on load. */
  open?: boolean;
  class?: string;
  [key: string]: unknown;
  /** Highlights the text and border with the theme's primary accent color when open */
  highlight?: boolean;
}

const { title, open = false, class: className, highlight = false, ...rest } = Astro.props;
---

<div
  class={cn(
    "not-last:border-b",
    // Accent open state border
    highlight && "has-[[aria-expanded=true]]:border-primary",
    className,
  )}
  data-accordion-03-item
  {...rest}
>
  <h3>
    <button
      type="button"
      data-accordion-03-trigger
      aria-expanded={open ? "true" : "false"}
      class={cn(
        "group/accordion-trigger relative flex flex-1 items-start justify-between gap-3 rounded-lg border-transparent py-2.5 text-left text-sm font-medium transition-all outline-none hover:underline focus-visible:border-ring focus-visible:ring-3 focus-visible:ring-ring/50 focus-visible:after:border-ring aria-disabled:pointer-events-none aria-disabled:opacity-50 **:data-[slot=accordion-trigger-icon]:ml-auto **:data-[slot=accordion-trigger-icon]:size-4 **:data-[slot=accordion-trigger-icon]:text-muted-foreground",
        // Accent open state text and icons
        highlight && "aria-expanded:text-primary [&_svg]:group-aria-expanded/accordion-trigger:text-primary",
      )}
    >
      <!-- Down Icon -->
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
        class="pointer-events-none ml-auto size-4 shrink-0 text-muted-foreground group-aria-expanded/accordion-trigger:hidden"
      >
        <path d="m6 9 6 6 6-6"></path>
      </svg>

      <!-- Up Icon -->
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
        class="pointer-events-none ml-auto hidden size-4 shrink-0 text-muted-foreground group-aria-expanded/accordion-trigger:inline"
      >
        <path d="m18 15-6-6-6 6"></path>
      </svg>
      <slot name="icon" />
      {title}
    </button>
  </h3>
  <div
    data-accordion-03-panel
    data-state={open ? "open" : "closed"}
    class="grid grid-rows-[0fr] transition-[grid-template-rows] duration-200 data-[state=open]:grid-rows-[1fr]"
  >
    <div class="overflow-hidden">
      <!-- The inner spacing classes applied from the React AccordionContent function -->
      <div
        class="ml-14 pt-0 pb-2.5 text-sm text-muted-foreground [&_a]:underline [&_a]:underline-offset-3 [&_a]:hover:text-foreground [&_p:not(:last-child)]:mb-4"
      >
        <slot />
      </div>
    </div>
  </div>
</div>
