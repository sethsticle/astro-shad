---
/**
 * MapControls.astro -- astro-shad map controls. Converted from mapcn's
 * map.tsx MapControls/ControlGroup/ControlButton/CompassButton: zoom in/out,
 * compass (live bearing+pitch needle, click resets north), locate (geolocation
 * + flyTo, 10s timeout so a dismissed permission prompt doesn't wedge the
 * button), and fullscreen toggle on the map container. lucide-react icons
 * inlined as SVGs per the icon rule; hover surfaces use `bg-muted` (mapcn
 * used hover:bg-accent + a dark: variant -- registry markup carries no
 * dark: variants, tokens flip instead; `bg-accent` would now also work
 * since the 2026-07-20 realignment made `--accent` numerically identical
 * to `--muted`, but `bg-muted` stays the explicit, unambiguous choice).
 *
 * Must be a child of <Map>. A successful locate dispatches `map:locate`
 * (detail: { longitude, latitude }) on the map root.
 *
 *   <MapControls showCompass showLocate showFullscreen />
 */
import { cn } from '../../lib/utils';

interface Props {
  /** Corner of the map (default: "bottom-right"). */
  position?: 'top-left' | 'top-right' | 'bottom-left' | 'bottom-right';
  showZoom?: boolean;
  showCompass?: boolean;
  showLocate?: boolean;
  showFullscreen?: boolean;
  class?: string;
}

const {
  position = 'bottom-right',
  showZoom = true,
  showCompass = false,
  showLocate = false,
  showFullscreen = false,
  class: className,
} = Astro.props;

const POSITIONS: Record<NonNullable<Props['position']>, string> = {
  'top-left': 'top-2 left-2',
  'top-right': 'top-2 right-2',
  'bottom-left': 'bottom-2 left-2',
  // bottom-right sits above MapLibre's compact attribution control
  'bottom-right': 'bottom-10 right-2',
};

const GROUP =
  'flex flex-col overflow-hidden rounded-md border border-border bg-background shadow-sm ' +
  '[&>button:not(:last-child)]:border-b [&>button:not(:last-child)]:border-border';

const BTN =
  'flex size-8 cursor-pointer items-center justify-center transition-colors ' +
  'first:rounded-t-md last:rounded-b-md hover:bg-muted ' +
  'focus-visible:ring-2 focus-visible:ring-inset focus-visible:ring-ring focus-visible:outline-none ' +
  'disabled:pointer-events-none disabled:opacity-50';
---

<div
  data-astro-shad-map-controls
  class={cn('absolute z-10 flex flex-col gap-1.5', POSITIONS[position], className)}
>
  {
    showZoom && (
      <div class={GROUP}>
        <button type="button" class={BTN} data-map-action="zoom-in" aria-label="Zoom in">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="size-4"
          >
            <path d="M5 12h14" />
            <path d="M12 5v14" />
          </svg>
        </button>
        <button type="button" class={BTN} data-map-action="zoom-out" aria-label="Zoom out">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="size-4"
          >
            <path d="M5 12h14" />
          </svg>
        </button>
      </div>
    )
  }

  {
    showCompass && (
      <div class={GROUP}>
        <button
          type="button"
          class={BTN}
          data-map-action="compass"
          aria-label="Reset bearing to north"
        >
          <svg
            data-compass-needle
            viewBox="0 0 24 24"
            class="size-5"
            style="transform-style: preserve-3d"
          >
            <path d="M12 2L16 12H12V2Z" class="fill-red-500" />
            <path d="M12 2L8 12H12V2Z" class="fill-red-300" />
            <path d="M12 22L16 12H12V22Z" class="fill-muted-foreground/60" />
            <path d="M12 22L8 12H12V22Z" class="fill-muted-foreground/30" />
          </svg>
        </button>
      </div>
    )
  }

  {
    showLocate && (
      <div class={GROUP}>
        <button
          type="button"
          class={BTN}
          data-map-action="locate"
          aria-label="Find my location"
        >
          <svg
            data-locate-icon
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="size-4"
          >
            <line x1="2" x2="5" y1="12" y2="12" />
            <line x1="19" x2="22" y1="12" y2="12" />
            <line x1="12" x2="12" y1="2" y2="5" />
            <line x1="12" x2="12" y1="19" y2="22" />
            <circle cx="12" cy="12" r="7" />
          </svg>
          <svg
            data-locate-spinner
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="hidden size-4 animate-spin"
          >
            <path d="M21 12a9 9 0 1 1-6.219-8.56" />
          </svg>
        </button>
      </div>
    )
  }

  {
    showFullscreen && (
      <div class={GROUP}>
        <button
          type="button"
          class={BTN}
          data-map-action="fullscreen"
          aria-label="Toggle fullscreen"
        >
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="size-4"
          >
            <path d="M8 3H5a2 2 0 0 0-2 2v3" />
            <path d="M21 8V5a2 2 0 0 0-2-2h-3" />
            <path d="M3 16v3a2 2 0 0 0 2 2h3" />
            <path d="M16 21h3a2 2 0 0 0 2-2v-3" />
          </svg>
        </button>
      </div>
    )
  }
</div>

<script>
  import type MapLibreGL from 'maplibre-gl';

  // Map may init before or after us -- script bundling order is not guaranteed.
  function whenMapReady(
    el: HTMLElement,
    cb: (map: MapLibreGL.Map, mapRoot: HTMLElement) => void,
  ) {
    const mapRoot = el.closest<HTMLElement>('[data-astro-shad-map]');
    if (!mapRoot) return;
    const existing = (mapRoot as HTMLElement & { __astroShadMap?: MapLibreGL.Map }).__astroShadMap;
    if (existing) cb(existing, mapRoot);
    else
      mapRoot.addEventListener(
        'map:ready',
        (e) => cb((e as CustomEvent).detail.map, mapRoot),
        { once: true },
      );
  }

  function initControls(el: HTMLElement) {
    whenMapReady(el, (map, mapRoot) => {
      el.querySelector('[data-map-action="zoom-in"]')?.addEventListener('click', () => {
        map.zoomTo(map.getZoom() + 1, { duration: 300 });
      });
      el.querySelector('[data-map-action="zoom-out"]')?.addEventListener('click', () => {
        map.zoomTo(map.getZoom() - 1, { duration: 300 });
      });

      const compassBtn = el.querySelector<HTMLButtonElement>('[data-map-action="compass"]');
      if (compassBtn) {
        const needle = compassBtn.querySelector<SVGElement>('[data-compass-needle]');
        const updateNeedle = () => {
          if (!needle) return;
          needle.style.transform = `rotateX(${map.getPitch()}deg) rotateZ(${-map.getBearing()}deg)`;
        };
        map.on('rotate', updateNeedle);
        map.on('pitch', updateNeedle);
        updateNeedle();
        compassBtn.addEventListener('click', () => map.resetNorthPitch({ duration: 300 }));
      }

      const locateBtn = el.querySelector<HTMLButtonElement>('[data-map-action="locate"]');
      if (locateBtn) {
        const icon = locateBtn.querySelector('[data-locate-icon]');
        const spinner = locateBtn.querySelector('[data-locate-spinner]');
        const setWaiting = (waiting: boolean) => {
          locateBtn.disabled = waiting;
          icon?.classList.toggle('hidden', waiting);
          spinner?.classList.toggle('hidden', !waiting);
        };
        locateBtn.addEventListener('click', () => {
          if (!('geolocation' in navigator)) return;
          setWaiting(true);
          navigator.geolocation.getCurrentPosition(
            (pos) => {
              const coords = {
                longitude: pos.coords.longitude,
                latitude: pos.coords.latitude,
              };
              map.flyTo({
                center: [coords.longitude, coords.latitude],
                zoom: 14,
                duration: 1500,
              });
              mapRoot.dispatchEvent(new CustomEvent('map:locate', { detail: coords }));
              setWaiting(false);
            },
            (error) => {
              console.error('Error getting location:', error);
              setWaiting(false);
            },
            // Without a timeout the spec default is Infinity: a dismissed
            // permission prompt would leave the button disabled forever.
            { timeout: 10000 },
          );
        });
      }

      el.querySelector('[data-map-action="fullscreen"]')?.addEventListener('click', () => {
        if (document.fullscreenElement) {
          document.exitFullscreen();
        } else {
          mapRoot.requestFullscreen();
        }
      });
    });
  }

  document
    .querySelectorAll<HTMLElement>('[data-astro-shad-map-controls]')
    .forEach(initControls);
</script>
