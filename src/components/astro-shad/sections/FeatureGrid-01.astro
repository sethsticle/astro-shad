---
/**
 * FeatureGrid-01.astro -- layout section: centered heading block above a
 * 3/4-column card grid. Ships populated (frontend-contract.md §7):
 * <FeatureGrid01 /> renders a complete block; make it yours by editing
 * this copy you own (swap the Cards for your own cells).
 *
 * `columns` picks the lg+ column count; below lg the grid steps down to
 * 2 then 1. Ships three demo cards -- add a fourth when columns={4}.
 */
import { cn } from "../../../lib/utils";
import Card from "../Card.astro";

interface Props {
  /** lg+ column count for the items grid. */
  columns?: 3 | 4;
  class?: string;
  [key: string]: unknown;
}

const { columns = 3, class: className, ...rest } = Astro.props;
---

<section class={cn("py-16 md:py-24", className)} {...rest}>
  <div class="mx-auto w-full max-w-6xl px-6">
    <div class="mx-auto mb-12 flex max-w-2xl flex-col items-center gap-4 text-center">
      <!-- heading block — yours to edit: comment out and replace -->
      <h2 class="text-3xl font-semibold tracking-tight md:text-4xl">Why teams pick this stack</h2>
      <p class="text-muted-foreground">Three to four cells of proof. Keep each one to a claim and a sentence.</p>
    </div>
    <div class={cn("grid gap-4 sm:grid-cols-2", columns === 4 ? "lg:grid-cols-4" : "lg:grid-cols-3")}>
      <!-- items — swap these Cards for your own cells -->
      <Card title="Token-driven" description="Re-brand by changing values in theme.css, never markup." />
      <Card title="Zero runtime" description="HTML + Tailwind + a little vanilla JS. Nothing hydrates." />
      <Card title="Copy-and-own" description="Installed files are yours. Edit them like you wrote them." />
      <Card title="Copy-and-own" description="Installed files are yours. Edit them like you wrote them." />
    </div>
  </div>
</section>
