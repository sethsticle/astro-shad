---
/**
 * FeatureSection-01.astro -- layout section: left-aligned header block
 * (heading / subtext / outline CTA) above a 2/3-column grid of icon
 * feature cards. Converted from a shadcn-studio features section: the
 * Avatar icon tile becomes a token-tinted div, per-card color props
 * become one neutral hover treatment, cards are plain markup (no Card
 * dep). Zero client JS.
 *
 * Ships populated (frontend-contract.md §7): <FeatureSection01 />
 * renders a complete block; make it yours by editing this copy you own.
 */
import { cn } from "../../../lib/utils";
import Button from "../Button.astro";

interface Props {
  class?: string;
  [key: string]: unknown;
}

const { class: className, ...rest } = Astro.props;

/* Demo content -- swap for your own. Icon = inline lucide path(s). */
const FEATURES = [
  {
    title: "Secure checkout",
    description: "Every transaction is encrypted end to end, with fraud monitoring that never sleeps.",
    icon: '<rect width="18" height="11" x="3" y="11" rx="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path>',
  },
  {
    title: "Instant search",
    description: "Find any product in milliseconds with typo-tolerant, filter-aware search.",
    icon: '<circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path>',
  },
  {
    title: "Lightning performance",
    description: "Static pages, zero hydration. The storefront paints before the coffee cools.",
    icon: '<path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"></path>',
  },
  {
    title: "Saved favourites",
    description: "Wishlists sync across devices, so the cart is ready wherever they come back.",
    icon: '<path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"></path>',
  },
  {
    title: "Flexible payments",
    description: "Cards, wallets, and instalments out of the box -- currencies handled for you.",
    icon: '<rect width="20" height="14" x="2" y="5" rx="2"></rect><path d="M2 10h20"></path>',
  },
  {
    title: "Buyer protection",
    description: "Clear returns and dispute resolution baked in, so trust compounds with every order.",
    icon: '<path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"></path>',
  },
];
---

<section class={cn("py-16 md:py-24", className)} {...rest}>
  <div class="mx-auto w-full max-w-6xl px-6">
    <div class="mb-12 flex max-w-2xl flex-col items-start gap-4 sm:mb-16">
      <!-- content — yours to edit: comment out and replace -->
      <h2 class="text-2xl font-semibold tracking-tight md:text-3xl lg:text-4xl">Discover the exclusive perks today</h2>
      <p class="text-lg text-muted-foreground">
        Explore key features designed to enhance your shopping experience with intuitive navigation, robust security,
        and seamless functionality.
      </p>
      <Button variant="outline" size="lg" href="#">
        See all features
        <svg
          slot="icon-right"
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M5 12h14"></path>
          <path d="m12 5 7 7-7 7"></path>
        </svg>
      </Button>
    </div>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      <!-- feature cards — yours to edit: adjust FEATURES in the frontmatter -->
      {
        FEATURES.map((f) => (
          <div class="rounded-lg border border-border bg-card p-6 transition-colors duration-300 hover:border-primary/40">
            <div class="mb-6 grid size-12 place-items-center rounded-md bg-primary/10 text-primary">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                set:html={f.icon}
              />
            </div>
            <h3 class="mb-2 text-lg font-semibold">{f.title}</h3>
            <p class="text-muted-foreground">{f.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
