---
/**
 * Split-01.astro -- layout section: normal-height half/half split, media
 * beside content. Ships populated (frontend-contract.md §7): <Split01 />
 * renders a complete block; make it yours by editing this copy you own.
 * The media half ships as a token-styled placeholder surface -- swap the
 * div for your <img>/<video>.
 *
 * `reverse` flips the media to the right at md+ (source order is
 * unchanged, so mobile always stacks media-first).
 */
import { cn } from "../../../lib/utils";
import Button from "../Button.astro";

interface Props {
  /** Media on the right at md+ instead of the left. */
  reverse?: boolean;
  class?: string;
  [key: string]: unknown;
}

const { reverse = false, class: className, ...rest } = Astro.props;
---

<section class={cn("py-16 md:py-24", className)} {...rest}>
  <div class="mx-auto grid w-full max-w-6xl items-center gap-10 px-6 md:grid-cols-2 md:gap-16">
    <div class={cn(reverse && "md:order-last")}>
      <!-- media — swap this surface for your <img> or <video> -->
      <div class="grid aspect-[4/3] w-full place-items-center rounded-lg border border-border bg-muted">
        <span class="text-xs text-muted-foreground">media</span>
      </div>
    </div>
    <div class="flex flex-col gap-6">
      <!-- content — yours to edit: comment out and replace -->
      <h2 class="text-3xl font-semibold tracking-tight md:text-4xl">Half picture, half point.</h2>
      <p class="text-muted-foreground">
        The workhorse section: media on one side, the argument on the other. Alternate the `reverse` prop down the page for rhythm.
      </p>
      <div class="flex gap-3">
        <Button>Learn more</Button>
      </div>
    </div>
  </div>
</section>
