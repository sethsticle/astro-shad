import Hero01 from "../components/astro-shad/sections/Hero-01.astro";
import Hero02 from "../components/astro-shad/sections/Hero-02.astro";
import Hero03 from "../components/astro-shad/sections/Hero-03.astro";
import Hero04 from "../components/astro-shad/sections/Hero-04.astro";
import GsapHero01 from "../components/astro-shad/sections/GsapHero-01.astro";
import Split01 from "../components/astro-shad/sections/Split-01.astro";
import FeatureGrid01 from "../components/astro-shad/sections/FeatureGrid-01.astro";
import FeatureSection01 from "../components/astro-shad/sections/FeatureSection-01.astro";
import FeatureSection02 from "../components/astro-shad/sections/FeatureSection-02.astro";
import Cta01 from "../components/astro-shad/sections/Cta-01.astro";
import Cta02 from "../components/astro-shad/sections/Cta-02.astro";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>astro-shad / dev</title>
    <!-- dev-only font menu; components never ship font dependencies -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Space+Grotesk:wght@400;500;600&family=Playfair+Display:wght@500;600&family=JetBrains+Mono:wght@400;500&display=swap"
    />
  </head>
  <body class="h-screen overflow-hidden bg-[#0b0b0c] font-sans text-[#e4e4e7] antialiased">
    <div class="flex h-full gap-3 p-3">
      <!-- ── Sidebar: token controls (chrome -- fixed palette) ── -->
      <aside id="sidebar" class="z-40 flex w-72 flex-none flex-col overflow-hidden rounded-lg border border-[#26262b] bg-[#131316]">
        <header class="border-b border-[#26262b] px-5 py-4">
          <p class="text-[9px] font-semibold tracking-[0.2em] text-[#6e6e76]">ASTRO-SHAD</p>
          <h1 class="mt-1 text-base font-semibold">Playground</h1>
          <p class="mt-1 text-xs leading-relaxed text-[#6e6e76]">
            Overrides apply to the components in the boards only. Session-only until copied into theme.css.
          </p>
        </header>

        <div class="flex-1 space-y-6 overflow-y-auto px-5 py-5">
          <div>
            <p class="ctl-label">Mode</p>
            <div class="grid grid-cols-2 gap-1.5" data-group="mode">
              <button class="ctl" data-value="dark">Dark</button>
              <button class="ctl" data-value="light">Light</button>
            </div>
          </div>

          <div>
            <p class="ctl-label">Theme preset</p>
            <div class="grid grid-cols-2 gap-1.5" data-group="preset">
              <button class="ctl" data-value="default">Default</button>
              <button class="ctl" data-value="violet">Violet</button>
              <button class="ctl" data-value="blue">Blue</button>
              <button class="ctl" data-value="emerald">Emerald</button>
              <button class="ctl" data-value="rose">Rose</button>
              <button class="ctl" data-value="amber">Amber</button>
            </div>
          </div>

          <div>
            <p class="ctl-label">Base color</p>
            <div class="grid grid-cols-3 gap-1.5" data-group="base">
              <button class="ctl" data-value="neutral">Neutral</button>
              <button class="ctl" data-value="stone">Stone</button>
              <button class="ctl" data-value="zinc">Zinc</button>
              <button class="ctl" data-value="slate">Slate</button>
              <button class="ctl" data-value="gray">Gray</button>
            </div>
          </div>

          <div>
            <p class="ctl-label">Accent</p>
            <div class="flex flex-wrap items-center gap-2.5" data-group="accent">
              <button
                class="dot"
                data-value="none"
                style="background:linear-gradient(135deg,#fafafa 50%,#0a0a0a 50%)"
                aria-label="Preset accent"></button>
              <button class="dot" data-value="#8b5cf6" style="background:#8b5cf6" aria-label="Violet accent"></button>
              <button class="dot" data-value="#3b82f6" style="background:#3b82f6" aria-label="Blue accent"></button>
              <button class="dot" data-value="#10b981" style="background:#10b981" aria-label="Emerald accent"></button>
              <button class="dot" data-value="#f43f5e" style="background:#f43f5e" aria-label="Rose accent"></button>
              <button class="dot" data-value="#f59e0b" style="background:#f59e0b" aria-label="Amber accent"></button>
              <input
                id="accent-custom"
                type="color"
                value="#8b5cf6"
                aria-label="Custom accent"
                class="h-6 w-6 cursor-pointer rounded-full border border-[#26262b] bg-transparent"
              />
            </div>
          </div>

          <div>
            <p class="ctl-label">Heading font</p>
            <div class="grid grid-cols-1 gap-1.5" data-group="headingFont">
              <button class="ctl" data-value="default">Inherit content font</button>
              <button class="ctl" data-value="grotesk" style="font-family:'Space Grotesk',sans-serif">Space Grotesk</button>
              <button class="ctl" data-value="playfair" style="font-family:'Playfair Display',serif">Playfair Display</button>
              <button class="ctl" data-value="mono" style="font-family:'JetBrains Mono',monospace">JetBrains Mono</button>
            </div>
          </div>

          <div>
            <p class="ctl-label">Content font</p>
            <div class="grid grid-cols-1 gap-1.5" data-group="contentFont">
              <button class="ctl" data-value="default">System</button>
              <button class="ctl" data-value="inter" style="font-family:'Inter',sans-serif">Inter</button>
              <button class="ctl" data-value="grotesk" style="font-family:'Space Grotesk',sans-serif">Space Grotesk</button>
              <button class="ctl" data-value="mono" style="font-family:'JetBrains Mono',monospace">JetBrains Mono</button>
            </div>
          </div>

          <div>
            <p class="ctl-label">Radius</p>
            <div class="grid grid-cols-3 gap-1.5" data-group="radius">
              <button class="ctl" data-value="default">Default</button>
              <button class="ctl" data-value="0">0</button>
              <button class="ctl" data-value="0.3">0.3</button>
              <button class="ctl" data-value="0.5">0.5</button>
              <button class="ctl" data-value="0.75">0.75</button>
              <button class="ctl" data-value="1">1.0</button>
            </div>
          </div>
        </div>

        <footer class="space-y-2.5 border-t border-[#26262b] px-5 py-4">
          <pre
            id="readout"
            class="max-h-40 overflow-y-auto rounded-sm border border-[#26262b] bg-[#0b0b0c] p-3 text-[10px] leading-relaxed text-[#9d9da6]">
          </pre>
          <div class="grid grid-cols-2 gap-1.5">
            <button id="copy-tokens" class="ctl">Copy tokens</button>
            <button id="reset-tokens" class="ctl">Reset</button>
          </div>
        </footer>
      </aside>

      <!-- mobile backdrop for the off-canvas sidebar -->
      <div id="sidebar-backdrop" class="fixed inset-0 z-30 hidden bg-black/60 md:hidden"></div>

      <!-- ── Canvas: horizontal board scroller (chrome frame) ── -->
      <div class="relative min-w-0 flex-1">
        <button
          id="sidebar-toggle"
          class="absolute top-2 left-2 z-20 grid h-9 w-9 cursor-pointer place-items-center rounded-md border border-[#26262b] bg-[#131316] text-[#e4e4e7] shadow-lg"
          aria-label="Toggle sidebar"
          aria-expanded="true"
        >
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"><rect width="18" height="18" x="3" y="3" rx="2"></rect><path d="M9 3v18"></path></svg
          >
        </button>

        <!-- Icon source for the per-dev-group viewport toggles JS builds below.
             Rendered once at build time (astro-icon is build-time only) then
             cloned per group at runtime -- never displayed itself. -->
        <template id="viewport-icons">
          <span data-icon="phone"><Icon name="lucide:smartphone" size={12} /></span>
          <span data-icon="tablet"><Icon name="lucide:tablet" size={12} /></span>
          <span data-icon="laptop"><Icon name="lucide:laptop" size={12} /></span>
        </template>

        <div class="h-full overflow-hidden rounded-lg border border-[#26262b]">
          <!-- #preview-scope: ALL token overrides + data-theme land here -->
          <div id="preview-scope" class="flex h-full snap-x snap-mandatory overflow-x-auto scroll-smooth">
            <DevBoard index={1} title="Buttons & Badges" note="Button.astro · Badge.astro">
              <div class="dev-group">
                <p class="dev-group-title">Button variants</p>
                <div class="dev-row">
                  <Button>Primary</Button>
                  <Button variant="secondary">Secondary</Button>
                  <Button variant="inverse">Inverse</Button>
                  <Button variant="outline">Outline</Button>
                  <Button variant="ghost">Ghost</Button>
                  <Button variant="destructive">Destructive</Button>
                </div>
              </div>
              <div class="dev-group">
                <p class="dev-group-title">Sizes & states</p>
                <div class="dev-row">
                  <Button size="sm">Small</Button>
                  <Button size="md">Medium</Button>
                  <Button size="lg">Large</Button>
                  <Button disabled>Disabled</Button>
                  <Button href="#" variant="outline">As link</Button>
                </div>
              </div>
              <div class="dev-group">
                <p class="dev-group-title">Icon slots -- astro-icon rendered at build time, zero runtime</p>
                <div class="dev-row">
                  <Button><Icon slot="icon-left" name="lucide:download" size={16} />Download</Button>
                  <Button variant="secondary"><Icon slot="icon-left" name="lucide:plus" size={16} />New item</Button>
                  <Button variant="outline">Next<Icon slot="icon-right" name="lucide:arrow-right" size={16} /></Button>
                  <Button variant="ghost"
                    ><Icon slot="icon-left" name="lucide:settings" size={16} />Settings<Icon
                      slot="icon-right"
                      name="lucide:chevron-down"
                      size={14}
                    /></Button
                  >
                  <Button variant="destructive"><Icon slot="icon-left" name="lucide:trash-2" size={16} />Delete</Button>
                </div>
              </div>
              <div class="dev-group">
                <p class="dev-group-title">Badges</p>
                <div class="dev-row">
                  <Badge>Primary</Badge>
                  <Badge variant="secondary">Secondary</Badge>
                  <Badge variant="destructive">Destructive</Badge>
                  <Badge variant="outline">Outline</Badge>
                  <Badge variant="accent">Accent</Badge>
                  <Badge variant="outline" href="#">As link</Badge>
                </div>
              </div>

              <div class="dev-group">
                <p class="dev-group-title">ButtonGroup -- horizontal, separator, text cell, vertical, nested split</p>
                <div class="flex flex-wrap items-start gap-6">
                  <ButtonGroup>
                    <Button variant="outline" size="sm">Copy</Button>
                    <Button variant="outline" size="sm">Paste</Button>
                    <Button variant="outline" size="sm">Cut</Button>
                  </ButtonGroup>
                  <ButtonGroup>
                    <Button variant="secondary" size="sm">Undo</Button>
                    <ButtonGroupSeparator />
                    <Button variant="secondary" size="sm">Redo</Button>
                  </ButtonGroup>
                  <ButtonGroup>
                    <ButtonGroupText>https://</ButtonGroupText>
                    <Button variant="outline" size="sm">example.com</Button>
                  </ButtonGroup>
                  <ButtonGroup orientation="vertical">
                    <Button variant="outline" size="sm">Top</Button>
                    <Button variant="outline" size="sm">Middle</Button>
                    <Button variant="outline" size="sm">Bottom</Button>
                  </ButtonGroup>
                  <ButtonGroup>
                    <ButtonGroup>
                      <Button size="sm">Save</Button>
                    </ButtonGroup>
                    <ButtonGroup>
                      <Button variant="outline" size="sm" aria-label="More options">
                        <Icon slot="icon-left" name="lucide:chevron-down" size={14} />
                      </Button>
                    </ButtonGroup>
                  </ButtonGroup>
                </div>
              </div>
            </DevBoard>

            <DevBoard index={2} title="Cards" note="Card.astro · props + named slots · image / bgImage / imageSide">
              <div class="grid gap-4 sm:grid-cols-2">
                <Card title="Notifications" description="Choose how you want to be reached.">
                  <p class="text-sm text-muted-foreground">
                    Body content lives in the default slot. Header spacing collapses when no title, description, or header slot is given.
                  </p>
                  <div slot="footer" class="flex gap-2">
                    <Button size="sm">Save</Button>
                    <Button size="sm" variant="ghost">Cancel</Button>
                  </div>
                </Card>
                <Card>
                  <p class="text-sm text-muted-foreground">Bare card: no header, no footer -- just the default slot.</p>
                </Card>
                <Card
                  image="https://picsum.photos/seed/astro-shad/640/300"
                  imageAlt="Placeholder"
                  title="Image card"
                  description="image prop renders edge-to-edge above the header (imageSide default: top)."
                >
                  <p class="text-sm text-muted-foreground">The image slot wins over the prop when both exist.</p>
                </Card>
                <Card
                  bgImage="https://picsum.photos/seed/astro-bg/640/400"
                  title="Background image"
                  description="Absolute cover layer behind the content with a bottom scrim."
                >
                  <p class="text-sm text-white/80">Text goes literal white -- the scrim is dark in both themes.</p>
                </Card>
              </div>
              <div class="mt-4 grid gap-4">
                <Card
                  image="https://picsum.photos/seed/astro-side-left/480/280"
                  imageAlt="Placeholder"
                  imageSide="left"
                  title='imageSide="left"'
                  description="Row at lg (image ~1/3 width, left column). Stacks image-first below lg."
                >
                  <p class="text-sm text-muted-foreground">Resize the preview to see the lg breakpoint switch.</p>
                </Card>
                <Card
                  image="https://picsum.photos/seed/astro-side-right/480/280"
                  imageAlt="Placeholder"
                  imageSide="right"
                  title='imageSide="right"'
                  description="Row at lg (image ~1/3 width, right column via lg:order-last). Still stacks image-first below lg."
                >
                  <p class="text-sm text-muted-foreground">Same row layout, mirrored -- order flips only at lg+.</p>
                </Card>
              </div>
            </DevBoard>

            <DevBoard index={3} title="Glass Icons & Folders" note="GlassIcon.astro · Folder.astro · react-bits conversions">
              <div class="dev-group">
                <p class="dev-group-title">Glass icons via astro-icon -- string names, inlined at build</p>
                <div class="flex flex-wrap items-start gap-6 pb-8">
                  <GlassIcon label="Coding"><Icon name="lucide:cpu" size={22} /></GlassIcon>
                  <GlassIcon accent="#60a5fa" label="Robotics"><Icon name="lucide:bot" size={22} /></GlassIcon>
                  <GlassIcon accent="#c084fc" label="Launch"><Icon name="lucide:rocket" size={22} /></GlassIcon>
                  <GlassIcon accent="#f59e0b" label="Learning"><Icon name="lucide:graduation-cap" size={22} /></GlassIcon>
                </div>
              </div>
              <div class="dev-group">
                <p class="dev-group-title">Glass icons with hardcoded inline SVG -- hover for label</p>
                <div class="flex flex-wrap items-start gap-6 pb-8">
                  <GlassIcon label="Default">
                    <svg
                      width="22"
                      height="22"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      ><rect width="16" height="16" x="4" y="4" rx="2"></rect><rect width="6" height="6" x="9" y="9"></rect><path
                        d="M15 2v2"></path><path d="M15 20v2"></path><path d="M2 15h2"></path><path d="M2 9h2"></path><path d="M20 15h2"
                      ></path><path d="M20 9h2"></path><path d="M9 2v2"></path><path d="M9 20v2"></path></svg
                    >
                  </GlassIcon>
                  <GlassIcon accent="#60a5fa" label="Blue accent">
                    <svg
                      width="22"
                      height="22"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      ><path
                        d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"
                      ></path></svg
                    >
                  </GlassIcon>
                  <GlassIcon accent="#c084fc" label="As link" href="#glass">
                    <svg
                      width="22"
                      height="22"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      ><path
                        d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2Zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2"
                      ></path><path d="M18 14h-8"></path><path d="M15 18h-5"></path><path d="M10 6h8v4h-8V6Z"></path></svg
                    >
                  </GlassIcon>
                  <GlassIcon accent="#f59e0b">
                    <svg
                      width="22"
                      height="22"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      ><path
                        d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"
                      ></path></svg
                    >
                  </GlassIcon>
                </div>
              </div>
              <div class="dev-group">
                <p class="dev-group-title">Folders -- click to open, papers follow the cursor</p>
