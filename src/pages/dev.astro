---
/**
 * /dev -- the astro-shad playground. Every registry component renders
 * here before it ships (the "storybook" of the registry). New components
 * must add a <DevBoard>.
 *
 * Modeled on shadcn.com/create: a token-control sidebar, a bordered canvas
 * holding a horizontal snap scroller of DevBoard slides, and floating
 * pagination pills.
 *
 * ARCHITECTURE -- chrome vs preview:
 * The sidebar, canvas frame, board headers, and pills are CHROME: styled
 * once with fixed literal colors, never token utilities, so no control can
 * restyle them. All token overrides (and the dark/light attribute) land on
 * #preview-scope -- the scroller element -- as inline styles, so ONLY the
 * astro-shad components inside the boards respond. This works because
 * every component styles itself via var(--token) references and theme.css
 * scopes its light overrides with [data-theme="light"], not html[...].
 *
 * Radius note: --radius-sm/md/lg are defined at :root as calc() of
 * --radius, and var() inside a custom property resolves where it is
 * DECLARED -- so overriding --radius alone on the scope does nothing.
 * The radius control therefore sets all four vars directly.
 *
 * "Copy tokens" emits a theme.css-format override block (:root +
 * [data-theme="light"]) for graduating a trial into a consumer's theme.
 * Fonts load via a dev-only Google Fonts link; nothing ships with
 * components.
 */
import "../styles/global.css";
import { Icon } from "astro-icon/components";
import DevBoard from "../components/dev/DevBoard.astro";
import Button from "../components/astro-shad/Button.astro";
import Badge from "../components/astro-shad/Badge.astro";
import Card from "../components/astro-shad/Card.astro";
import Tabs from "../components/astro-shad/Tabs.astro";
import Accordion from "../components/astro-shad/Accordion.astro";
import AccordionItem from "../components/astro-shad/AccordionItem.astro";
import GlassIcon from "../components/astro-shad/GlassIcon.astro";
import Folder from "../components/astro-shad/Folder.astro";
import Pagination from "../components/astro-shad/Pagination.astro";
import BubbleMenu from "../components/astro-shad/BubbleMenu.astro";
import Form from "../components/astro-shad/Form.astro";
import FormField from "../components/astro-shad/FormField.astro";
import DatePicker from "../components/astro-shad/DatePicker.astro";
import MagicBento from "../components/astro-shad/MagicBento.astro";
import BentoCard from "../components/astro-shad/BentoCard.astro";
import TextType from "../components/astro-shad/TextType.astro";
import RotatingText from "../components/astro-shad/RotatingText.astro";
import SplitText from "../components/astro-shad/SplitText.astro";
import CountUp from "../components/astro-shad/CountUp.astro";
import CurvedLoop from "../components/astro-shad/CurvedLoop.astro";
import LogoLoop from "../components/astro-shad/LogoLoop.astro";
import LogosCarousel from "../components/astro-shad/LogosCarousel.astro";
import HighlightedText from "../components/astro-shad/HighlightedText.astro";
import ButtonGroup from "../components/astro-shad/ButtonGroup.astro";
import ButtonGroupText from "../components/astro-shad/ButtonGroupText.astro";
import ButtonGroupSeparator from "../components/astro-shad/ButtonGroupSeparator.astro";
import TopBar from "../components/astro-shad/TopBar.astro";
import FloatingHeader from "../components/astro-shad/FloatingHeader.astro";
import Map from "../components/astro-shad/Map.astro";
import MapMarker from "../components/astro-shad/MapMarker.astro";
import MapControls from "../components/astro-shad/MapControls.astro";
import MapPopup from "../components/astro-shad/MapPopup.astro";
import MapRoute from "../components/astro-shad/MapRoute.astro";
import MapGeoJSON from "../components/astro-shad/MapGeoJSON.astro";
import PulseGrid from "../components/astro-shad/PulseGrid.astro";
import PixelTransition from "../components/astro-shad/PixelTransition.astro";
import Separator from "../components/astro-shad/Separator.astro";
import Skeleton from "../components/astro-shad/Skeleton.astro";
import Input from "../components/astro-shad/Input.astro";
import Tooltip from "../components/astro-shad/Tooltip.astro";
import Sheet from "../components/astro-shad/Sheet.astro";
import Dialog from "../components/astro-shad/Dialog.astro";
import DropdownMenu from "../components/astro-shad/DropdownMenu.astro";
import DropdownMenuItem from "../components/astro-shad/DropdownMenuItem.astro";
import Checkbox from "../components/astro-shad/Checkbox.astro";
import Textarea from "../components/astro-shad/Textarea.astro";
import Combobox from "../components/astro-shad/Combobox.astro";
import Sidebar from "../components/astro-shad/Sidebar.astro";
import SidebarGroup from "../components/astro-shad/SidebarGroup.astro";
import SidebarMenuButton from "../components/astro-shad/SidebarMenuButton.astro";
import SidebarTrigger from "../components/astro-shad/SidebarTrigger.astro";
import SidebarInset from "../components/astro-shad/SidebarInset.astro";
import ThemeToggle from "../components/astro-shad/ThemeToggle.astro";
import { motion, motionStagger, MOTION_PREHIDE_CSS } from "../lib/motion";

/* Demo districts for the MapGeoJSON board: rough hand-drawn zones around
   Cape Town -- shapes are illustrative, not accurate boundaries. */
const DEMO_DISTRICTS = {
