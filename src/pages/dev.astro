          class="absolute bottom-4 left-1/2 flex max-w-[min(90vw,28rem)] -translate-x-1/2 gap-1 rounded-md border border-[#26262b] bg-[#131316] p-1 shadow-lg"
          aria-label="Boards"
        >
          <div id="pagination-scroll" class="flex gap-1 overflow-x-auto"></div>
        </nav>
      </div>
    </div>

    <style is:global>
      /* is:global because the pagination pills are created at runtime and
         would miss Astro's scoping attribute. All selectors are page-unique
         classes/ids. CHROME styles use fixed literal colors on purpose --
         the token controls must never restyle the shell. */
      .ctl-label {
        margin-bottom: 0.5rem;
        font-size: 0.6875rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #6e6e76;
      }
      .ctl {
        padding: 0.4rem 0.6rem;
        font-size: 0.75rem;
        font-weight: 500;
        color: #9d9da6;
        border: 1px solid #26262b;
        border-radius: 6px;
        background: transparent;
        cursor: pointer;
        transition: all 150ms ease;
      }
      .ctl:hover {
        color: #e4e4e7;
        border-color: #4b4b53;
      }
      .ctl[aria-pressed="true"] {
        background: #e4e4e7;
        border-color: #e4e4e7;
        color: #0b0b0c;
      }
      .dot {
        width: 1.5rem;
        height: 1.5rem;
        border-radius: 9999px;
        border: 1px solid #26262b;
        cursor: pointer;
      }
      .dot[aria-pressed="true"] {
        outline: 2px solid #e4e4e7;
        outline-offset: 2px;
      }
      .pill {
        padding: 0.35rem 0.6rem;
        font-size: 10px;
        font-weight: 600;
        color: #6e6e76;
        border-radius: 6px;
        background: transparent;
        border: none;
        cursor: pointer;
        transition: all 150ms ease;
      }
      .pill[aria-current="true"] {
        background: #e4e4e7;
        color: #0b0b0c;
      }
      .viewport-btn {
        display: grid;
        width: 1.5rem;
        height: 1.5rem;
        place-items: center;
        color: #9d9da6;
        background: transparent;
        border: none;
        border-radius: 5px;
        cursor: pointer;
        transition: all 150ms ease;
      }
      .viewport-btn:hover {
        color: #e4e4e7;
      }
      .viewport-btn[aria-pressed="true"] {
        background: #e4e4e7;
        color: #0b0b0c;
      }

      /* ── Per-dev-group viewport toggle ──
         JS (below) splits every .dev-group into a .group-header row (title
         + toggle, inline, far right) and a .group-canvas div holding
         everything else. The toggle lives in the title row -- not floated
         over the content -- so it never collides with a component's own
         top-right chrome (map zoom controls, etc). Each group narrows
         independently; toggling one never touches another, and the board
         header, sidebar, and pagination are untouched since they're outside
         .dev-group entirely. Only affects intrinsic layout (flex-wrap,
         grid, ButtonGroup, etc); sm:/md: utilities key off the actual
         browser viewport and won't re-trigger from a narrowed container. */
      .group-header {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 1rem;
      }
      .group-header .dev-group-title {
        flex: 1;
        margin-bottom: 0;
      }
      .group-canvas {
        max-width: 100%;
        margin-inline: auto;
        transition: max-width 200ms ease;
      }
      .group-canvas[data-viewport="phone"] {
        max-width: 375px;
      }
      .group-canvas[data-viewport="tablet"] {
        max-width: 768px;
      }
      /* height, not max-height -- min-h-svh below needs a DEFINITE ancestor
         height to resolve its own min-height:100% against. A percentage
         height against an auto-height ancestor computes to nothing. */
      .tall-canvas .group-canvas[data-viewport="phone"] {
        height: 800px;
        overflow-y: auto;
      }
      .tall-canvas .group-canvas[data-viewport="tablet"] {
        height: 768px;
        overflow-y: auto;
      }
      /* Board markup usually wraps the demo in its own div (e.g. the
         overflow-hidden/rounded-lg/border-border box around <Hero01 />) --
         that div has no height of its own, which breaks the percentage
         chain the min-h-svh override below depends on. flex + stretch
         forces it to fill .group-canvas's definite height instead of
         sizing to its own auto content, so the chain reaches all the way
         down to the section. */
      .tall-canvas .group-canvas[data-viewport] {
        display: flex;
        flex-direction: column;
      }
      .tall-canvas .group-canvas[data-viewport] > * {
        flex: 1 1 auto;
        min-height: 0;
      }
      /* svh/dvh/vh always resolve against the REAL browser viewport, never
         a container -- so no wrapper sizing above can shrink a min-h-svh
         section on its own. Override it directly while narrowed so Hero
         sections fill the box we gave them instead of demanding the
         monitor's full height and scrolling inside it. */
      .tall-canvas .group-canvas[data-viewport] :is(.min-h-svh, .min-h-dvh, .min-h-screen) {
        min-height: 100%;
      }
      .group-viewport-toggle {
        flex: none;
        margin-left: auto;
        display: flex;
        align-items: center;
        gap: 0.125rem;
        padding: 0.25rem;
        border-radius: 6px;
        border: 1px solid #26262b;
        background: #131316;
      }

      /* Board content helpers (inside the preview scope -- token-styled) */
      .dev-group {
        margin-bottom: 2.5rem;
      }
      .dev-group-title {
        margin-bottom: 1rem;
        font-size: 0.6875rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--muted-foreground);
      }
      .dev-row {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.75rem;
      }

      /* Preview-scope font hooks: content font on the scope, heading font
         via one scoped rule. Unset by default -- inherit as normal. */
      #preview-scope {
        font-family: var(--font-content, inherit);
      }
      #preview-scope :is(h1, h2, h3, h4, h5, h6) {
        font-family: var(--font-heading, inherit);
      }

      /* Hide the scroller's own scrollbar; pills are the pagination */
      #preview-scope {
        scrollbar-width: none;
      }
      #preview-scope::-webkit-scrollbar {
        display: none;
      }

      /* Pagination pill strip: same scrollbar-hide treatment once the pill
         count overflows the nav's max-width (see the nav element). */
      #pagination-scroll {
        scrollbar-width: none;
      }
      #pagination-scroll::-webkit-scrollbar {
        display: none;
      }

      /* ── Collapsible sidebar ──
         Mobile: fixed off-canvas drawer. Desktop: static column that
         collapses away entirely. State = data-sidebar on <body>. */
      @media (max-width: 767px) {
        #sidebar {
          position: fixed;
          top: 0;
          bottom: 0;
          left: 0;
          border-radius: 0;
          transform: translateX(-100%);
          transition: transform 250ms ease;
        }
        body[data-sidebar="open"] #sidebar {
          transform: none;
        }
        body[data-sidebar="open"] #sidebar-backdrop {
          display: block;
        }
      }
      @media (min-width: 768px) {
        body[data-sidebar="closed"] #sidebar {
          display: none;
        }
      }
    </style>

    <script>
      /* ═══ Dev config ═══
         0-based board index to land on when this page loads -- change this
         while iterating on one board instead of scrolling/paging over each
         time. 0 = first board (the normal default). */
      const DEFAULT_BOARD = 20;

      /* ═══ Token controls ═══
         All overrides land as inline custom properties on #preview-scope,
         never :root -- chrome is untouched by design. */
      const scope = document.getElementById("preview-scope") as HTMLElement;
      const readout = document.getElementById("readout") as HTMLElement;

      const alpha = (hex: string, a: number) => {
        const n = parseInt(hex.slice(1), 16);
        return `rgb(${(n >> 16) & 255} ${(n >> 8) & 255} ${n & 255} / ${a})`;
      };
      const lum = (hex: string) => {
        const n = parseInt(hex.slice(1), 16);
        return (0.299 * ((n >> 16) & 255) + 0.587 * ((n >> 8) & 255) + 0.114 * (n & 255)) / 255;
      };
      /* readable text over an accent fill */
      const onColor = (hex: string) => (lum(hex) > 0.6 ? "#09090b" : "#fafafa");

      /* ── Base color: shadcn neutral families as full slot-var maps ── */
      type VarMap = Record<string, string>;
      const scale = (s50: string, s100: string, s200: string, s400: string, s800: string, s900: string, s950: string) => ({
        dark: {
          "--background": s950,
          "--foreground": s50,
          "--card": s900,
          "--card-foreground": s50,
          "--popover": s800,
          "--popover-foreground": s50,
          "--primary": s50,
          "--primary-foreground": s950,
          "--secondary": s800,
          "--secondary-foreground": s50,
          "--muted": s800,
          "--muted-foreground": alpha(s50, 0.45),
          "--accent": s800,
          "--accent-foreground": s50,
          "--border": alpha(s50, 0.12),
          "--input": alpha(s50, 0.15),
          "--ring": s400,
        },
        light: {
          "--background": s50,
          "--foreground": s900,
          "--card": "#ffffff",
          "--card-foreground": s900,
          "--popover": s100,
          "--popover-foreground": s900,
          "--primary": s900,
          "--primary-foreground": s50,
          "--secondary": s200,
          "--secondary-foreground": s900,
          "--muted": s100,
          "--muted-foreground": alpha(s900, 0.5),
          "--accent": s100,
          "--accent-foreground": s900,
          "--border": alpha(s900, 0.12),
          "--input": alpha(s900, 0.1),
          "--ring": s400,
        },
      });
      const BASES: Record<string, { dark: VarMap; light: VarMap }> = {
        neutral: scale("#fafafa", "#f5f5f5", "#e5e5e5", "#a3a3a3", "#262626", "#171717", "#0a0a0a"),
        stone: scale("#fafaf9", "#f5f5f4", "#e7e5e4", "#a8a29e", "#292524", "#1c1917", "#0c0a09"),
        zinc: scale("#fafafa", "#f4f4f5", "#e4e4e7", "#a1a1aa", "#27272a", "#18181b", "#09090b"),
        slate: scale("#f8fafc", "#f1f5f9", "#e2e8f0", "#94a3b8", "#1e293b", "#0f172a", "#020617"),
        gray: scale("#f9fafb", "#f3f4f6", "#e5e7eb", "#9ca3af", "#1f2937", "#111827", "#030712"),
      };

      /* ── Theme presets: arbitrary per-mode var maps.
         PASTE-FRIENDLY: tweakcn / shadcn theme.css presets drop straight in
         here as { dark: {...vars}, light: {...vars} } entries. ── */
      const preset = (dark: string, light: string) => ({
        dark: { "--primary": dark, "--primary-foreground": onColor(dark), "--ring": dark },
        light: { "--primary": light, "--primary-foreground": onColor(light), "--ring": light },
      });
      const PRESETS: Record<string, { dark: VarMap; light: VarMap }> = {
        default: { dark: {}, light: {} },
        violet: preset("#8b5cf6", "#7c3aed"),
        blue: preset("#3b82f6", "#2563eb"),
        emerald: preset("#10b981", "#059669"),
        rose: preset("#f43f5e", "#e11d48"),
        amber: preset("#f59e0b", "#d97706"),
      };

      const FONTS: Record<string, string> = {
        inter: "'Inter', system-ui, sans-serif",
        grotesk: "'Space Grotesk', system-ui, sans-serif",
        playfair: "'Playfair Display', serif",
        mono: "'JetBrains Mono', monospace",
      };

      const DEFAULTS = {
        mode: "light",
        preset: "default",
        base: "neutral",
        accent: "none",
        headingFont: "default",
        contentFont: "default",
        radius: "default",
      };
      type State = typeof DEFAULTS;
      const state: State = { ...DEFAULTS };

      /* Build the override map for one mode. Order: base neutrals, then
         preset (wins on what it sets), then accent, then radius/fonts. */
      function overridesFor(mode: "dark" | "light"): VarMap {
        const o: VarMap = {};
        if (state.base !== DEFAULTS.base) Object.assign(o, BASES[state.base][mode]);
        Object.assign(o, PRESETS[state.preset][mode]);
        if (state.accent !== "none") {
          o["--primary"] = state.accent;
          o["--primary-foreground"] = onColor(state.accent);
          o["--ring"] = state.accent;
        }
        if (state.radius !== "default") {
          /* --radius-sm/md/lg are calc()ed at :root, so var() inside them
             resolves there -- set all four here for the scope to win. */
          const r = parseFloat(state.radius);
          o["--radius"] = `${r}rem`;
          o["--radius-sm"] = `calc(${r}rem - 2px)`;
          o["--radius-md"] = `${r}rem`;
          o["--radius-lg"] = `calc(${r}rem + 2px)`;
        }
        if (state.headingFont !== "default") o["--font-heading"] = FONTS[state.headingFont];
        if (state.contentFont !== "default") o["--font-content"] = FONTS[state.contentFont];
        return o;
      }

      function apply() {
        /* mode: attribute on the SCOPE, not <html> -- theme.css light
           overrides are [data-theme="light"], so this flips only the
           preview area. Chrome never changes. */
        if (state.mode === "light") scope.dataset.theme = "light";
        else delete scope.dataset.theme;

        /* replace all inline vars with the current mode's override set */
        scope.removeAttribute("style");
        const current = overridesFor(state.mode as "dark" | "light");
        Object.entries(current).forEach(([k, v]) => scope.style.setProperty(k, v));

        /* pressed states */
        document.querySelectorAll<HTMLElement>("[data-group]").forEach((group) => {
          const key = group.dataset.group as keyof State;
          group.querySelectorAll<HTMLElement>("[data-value]").forEach((btn) => {
            btn.setAttribute("aria-pressed", String(btn.dataset.value === state[key]));
          });
        });

        /* readout: theme.css-format override block, both modes */
        const block = (sel: string, vars: VarMap) => {
          const keys = Object.keys(vars).filter((k) => !k.startsWith("--font-"));
          return keys.length ? `${sel} {\n${keys.map((k) => `  ${k}: ${vars[k]};`).join("\n")}\n}` : "";
        };
        const dark = overridesFor("dark");
        const light = overridesFor("light");
        const fonts = ["--font-heading", "--font-content"].filter((k) => dark[k]).map((k) => `  ${k}: ${dark[k]};`);
        const parts = [
          block(":root", dark),
          block('[data-theme="light"]', light),
          fonts.length ? `/* fonts: wire these up in your own global.css */\n:root {\n${fonts.join("\n")}\n}` : "",
        ].filter(Boolean);
        readout.textContent = parts.length ? parts.join("\n\n") : "/* no overrides -- at theme.css defaults */";
      }

      document.querySelectorAll<HTMLElement>("[data-group]").forEach((group) => {
        group.addEventListener("click", (e) => {
          const btn = (e.target as HTMLElement).closest<HTMLElement>("[data-value]");
          if (!btn) return;
          (state as Record<string, string>)[group.dataset.group!] = btn.dataset.value!;
          apply();
        });
      });

      const customAccent = document.getElementById("accent-custom") as HTMLInputElement;
      customAccent.addEventListener("input", () => {
        state.accent = customAccent.value;
        apply();
      });

      document.getElementById("reset-tokens")!.addEventListener("click", () => {
        Object.assign(state, DEFAULTS, { mode: state.mode });
        apply();
      });

      const copyBtn = document.getElementById("copy-tokens")!;
      copyBtn.addEventListener("click", () => {
        navigator.clipboard.writeText(readout.textContent || "").then(() => {
          const label = copyBtn.textContent;
          copyBtn.textContent = "Copied";
          setTimeout(() => (copyBtn.textContent = label), 1200);
        });
      });

      /* ═══ Collapsible sidebar ═══ */
      const sidebarToggle = document.getElementById("sidebar-toggle")!;
      const backdrop = document.getElementById("sidebar-backdrop")!;
      let sidebarOpen = matchMedia("(min-width: 768px)").matches;

      function syncSidebar() {
        document.body.dataset.sidebar = sidebarOpen ? "open" : "closed";
        sidebarToggle.setAttribute("aria-expanded", String(sidebarOpen));
      }
      sidebarToggle.addEventListener("click", () => {
        sidebarOpen = !sidebarOpen;
        syncSidebar();
      });
      backdrop.addEventListener("click", () => {
        sidebarOpen = false;
        syncSidebar();
      });

      /* ═══ Board pagination ═══ */
      const scroller = scope;
      const boards = scroller.querySelectorAll("[data-board]");
      const nav = document.getElementById("pagination-scroll")!;
      const pills: HTMLButtonElement[] = [];

      boards.forEach((_, i) => {
        const pill = document.createElement("button");
        pill.className = "pill";
        pill.textContent = String(i + 1).padStart(2, "0");
        pill.setAttribute("aria-label", `Board ${i + 1}`);
        pill.addEventListener("click", () => goTo(i));
        nav.appendChild(pill);
        pills.push(pill);
      });

      function goTo(i: number, behavior: ScrollBehavior = "smooth") {
        scroller.scrollTo({ left: i * scroller.clientWidth, behavior });
      }
      function currentIndex() {
        return Math.min(boards.length - 1, Math.max(0, Math.round(scroller.scrollLeft / scroller.clientWidth)));
      }
      function syncPills() {
        const idx = currentIndex();
        pills.forEach((p, i) => p.setAttribute("aria-current", String(i === idx)));
        pills[idx]?.scrollIntoView({ block: "nearest", inline: "nearest", behavior: "smooth" });
      }

      if (DEFAULT_BOARD > 0 && DEFAULT_BOARD < boards.length) {
        goTo(DEFAULT_BOARD, "instant");
      }
      syncPills();

      let ticking = false;
      scroller.addEventListener("scroll", () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(() => {
          syncPills();
          ticking = false;
        });
      });

      document.addEventListener("keydown", (e) => {
        const t = e.target as HTMLElement;
        if (t && /^(INPUT|TEXTAREA|SELECT)$/.test(t.tagName)) return;
        /* Tabs own their arrow keys -- do not flip boards */
        if (t && t.closest && t.closest('[role="tablist"]')) return;
        if (e.key === "ArrowRight") goTo(Math.min(boards.length - 1, currentIndex() + 1));
        if (e.key === "ArrowLeft") goTo(Math.max(0, currentIndex() - 1));
      });

      /* ═══ Per-dev-group viewport toggles ═══
         Every .dev-group gets its own phone/tablet/laptop toggle, top-right
         of its own canvas -- independent of every other group. Content
         after the title moves into a .group-canvas wrapper (CSS narrows
         that, not the group itself, so the title row stays put); the
         toggle button icons come from the astro-icon render in the
         #viewport-icons <template> since astro-icon is build-time only. */
      const iconTpl = document.getElementById("viewport-icons") as HTMLTemplateElement;
      const VIEWPORTS = ["phone", "tablet", "laptop"] as const;
      const VIEWPORT_LABELS: Record<(typeof VIEWPORTS)[number], string> = {
        phone: "Phone width",
        tablet: "Tablet width",
        laptop: "Full width",
      };
      const iconHTML = Object.fromEntries(
        VIEWPORTS.map((v) => [v, iconTpl.content.querySelector(`[data-icon="${v}"]`)!.innerHTML]),
      ) as Record<(typeof VIEWPORTS)[number], string>;

      document.querySelectorAll<HTMLElement>(".dev-group").forEach((group) => {
        const title = group.querySelector<HTMLElement>(":scope > .dev-group-title");
        const canvas = document.createElement("div");
        canvas.className = "group-canvas";
        Array.from(group.childNodes).forEach((node) => {
          if (node !== title) canvas.appendChild(node);
        });

        const toggle = document.createElement("div");
        toggle.className = "group-viewport-toggle";
        toggle.setAttribute("role", "group");
        toggle.setAttribute("aria-label", "Preview viewport width");
        toggle.innerHTML = VIEWPORTS.map(
          (v) =>
            `<button type="button" class="viewport-btn" data-value="${v}" aria-label="${VIEWPORT_LABELS[v]}" aria-pressed="${v === "laptop"}">${iconHTML[v]}</button>`,
        ).join("");

        const header = document.createElement("div");
        header.className = "group-header";
        if (title) header.appendChild(title);
        header.appendChild(toggle);

        group.replaceChildren(header, canvas);

        toggle.addEventListener("click", (e) => {
          const btn = (e.target as HTMLElement).closest<HTMLElement>("[data-value]");
          if (!btn) return;
          const value = btn.dataset.value as (typeof VIEWPORTS)[number];
          if (value === "laptop") delete canvas.dataset.viewport;
          else canvas.dataset.viewport = value;
          toggle.querySelectorAll<HTMLElement>("[data-value]").forEach((b) => b.setAttribute("aria-pressed", String(b === btn)));
        });
      });

      apply();
      syncSidebar();
      syncPills();
    </script>

    <!--
      Dev-only wiring for board 6 (Forms): intercepts the real POST to
      /api/contact via fetch (instead of a full navigation) purely so the
      round trip can be printed in the log panel beside it. Independent of
      Form.astro's own delegated script -- see docs/forms-and-submissions.md.
    -->
    <script>
      document.addEventListener("submit", async (e) => {
        const form = (e.target as HTMLElement | null)?.closest<HTMLFormElement>("[data-dev-form-log]");
        if (!form) return;
        if (!form.checkValidity()) return; // Form.astro's own listener handles inline errors

        e.preventDefault();

        const log = document.getElementById(form.dataset.logTarget ?? "");
        const write = (label: string, body: unknown) => {
          if (!log) return;
          const time = new Date().toLocaleTimeString();
          log.textContent += `\n[${time}] ${label}\n${JSON.stringify(body, null, 2)}\n`;
          log.scrollTop = log.scrollHeight;
        };

        const formData = new FormData(form);
        write(`--> ${form.method.toUpperCase()} ${form.getAttribute("action")}`, Object.fromEntries(formData.entries()));

        try {
          const res = await fetch(form.action, { method: form.method, body: formData });
          const json = await res.json();
          write(`<-- ${res.status} ${res.statusText}`, json);
          if (res.ok) form.reset();
        } catch (err) {
          write("<-- network error", { message: err instanceof Error ? err.message : String(err) });
        }
      });

      document.addEventListener("click", (e) => {
        const btn = (e.target as HTMLElement | null)?.closest<HTMLButtonElement>("[data-log-clear]");
        if (!btn) return;
        const log = document.getElementById(btn.dataset.logClear ?? "");
        if (log) log.textContent = "";
      });
    </script>
  </body>
</html>
