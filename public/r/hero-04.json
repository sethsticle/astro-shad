{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "hero-04",
  "title": "Hero 04 — split + feature row",
  "description": "Layout section, ships populated: split hero — headline/actions left, media panel right, icon-feature card row beneath. Simplified from a shadcn-studio restaurant hero; the media panel stands in for its carousel until the carousel primitive ships.",
  "registryDependencies": [
    "@astro-shad/utils",
    "@astro-shad/button"
  ],
  "files": [
    {
      "path": "src/components/astro-shad/sections/Hero-04.astro",
      "content": "---\n/**\n * Hero-04.astro -- layout section: split hero -- headline left, media\n * panel right, icon-feature card row beneath. Simplified from a\n * shadcn-studio restaurant hero (embla triple-synced carousel): the\n * media panel stands in for its main carousel and the feature row for\n * its thumbnail/comments strips, until the carousel primitive exists.\n * Ships populated (frontend-contract.md §7): <Hero04 /> renders a\n * complete block; make it yours by editing this copy you own.\n *\n * `background` slot: absolute layer behind everything, empty by default.\n */\nimport { cn } from \"../../../lib/utils\";\nimport Button from \"../Button.astro\";\n\ninterface Props {\n  class?: string;\n  [key: string]: unknown;\n}\n\nconst { class: className, ...rest } = Astro.props;\n---\n\n<section class={cn(\"relative isolate flex min-h-svh flex-col justify-center\", className)} {...rest}>\n  <div class=\"absolute inset-0 -z-10 overflow-hidden\"><slot name=\"background\" /></div>\n  <div class=\"mx-auto flex w-full max-w-6xl flex-col gap-16 px-6 py-16\">\n    <div class=\"grid items-center gap-10 lg:grid-cols-5 lg:gap-6\">\n      <div class=\"flex flex-col gap-5 max-lg:items-center max-lg:text-center lg:col-span-2\">\n        <!-- content — yours to edit: comment out and replace -->\n        <h1 class=\"text-3xl font-semibold tracking-tight text-balance sm:text-4xl lg:text-5xl\">Savor the taste of perfection.</h1>\n        <p class=\"max-w-xl text-lg text-muted-foreground\">\n          From sizzling appetisers to signature desserts, every dish is crafted to delight the senses.\n        </p>\n        <div class=\"flex items-center gap-4\">\n          <Button size=\"lg\" class=\"group rounded-full\">\n            Order now\n            <svg\n              slot=\"icon-right\"\n              xmlns=\"http://www.w3.org/2000/svg\"\n              width=\"16\"\n              height=\"16\"\n              viewBox=\"0 0 24 24\"\n              fill=\"none\"\n              stroke=\"currentColor\"\n              stroke-width=\"2\"\n              stroke-linecap=\"round\"\n              stroke-linejoin=\"round\"\n              aria-hidden=\"true\"\n              class=\"transition-transform duration-200 group-hover:translate-x-0.5\"\n            >\n              <path d=\"M5 12h14\"></path>\n              <path d=\"m12 5 7 7-7 7\"></path>\n            </svg>\n          </Button>\n          <Button size=\"lg\" variant=\"secondary\" class=\"rounded-full\">Book a table</Button>\n        </div>\n      </div>\n      <div class=\"lg:col-span-3\">\n        <!-- media — swap this surface for your <img>, or the carousel once it ships -->\n        <div class=\"grid aspect-square w-full place-items-center overflow-hidden rounded-lg border border-border bg-muted\">\n          <!-- <span class=\"text-xs text-muted-foreground\">media</span> -->\n          <img src=\"https://unsplash.com/photos/SpVw8IvJJjE/download?w=1920\" alt=\"\" class=\"h-full w-full object-cover\" />\n        </div>\n      </div>\n    </div>\n    <div class=\"grid grid-cols-[repeat(auto-fit,minmax(13rem,1fr))] gap-4\">\n      <!-- feature row — icon + text cards, yours to edit -->\n      <div class=\"flex items-start gap-3 rounded-lg border border-border bg-card p-4\">\n        <svg\n          xmlns=\"http://www.w3.org/2000/svg\"\n          width=\"18\"\n          height=\"18\"\n          viewBox=\"0 0 24 24\"\n          fill=\"none\"\n          stroke=\"currentColor\"\n          stroke-width=\"2\"\n          stroke-linecap=\"round\"\n          stroke-linejoin=\"round\"\n          aria-hidden=\"true\"\n          class=\"mt-0.5 shrink-0 text-primary\"\n        >\n          <path d=\"M13 2 3 14h9l-1 8 10-12h-9l1-8z\"></path>\n        </svg>\n        <div>\n          <p class=\"text-sm font-semibold\">Fresh daily</p>\n          <p class=\"text-sm text-muted-foreground\">Sourced every morning, plated the same day.</p>\n        </div>\n      </div>\n      <div class=\"flex items-start gap-3 rounded-lg border border-border bg-card p-4\">\n        <svg\n          xmlns=\"http://www.w3.org/2000/svg\"\n          width=\"18\"\n          height=\"18\"\n          viewBox=\"0 0 24 24\"\n          fill=\"none\"\n          stroke=\"currentColor\"\n          stroke-width=\"2\"\n          stroke-linecap=\"round\"\n          stroke-linejoin=\"round\"\n          aria-hidden=\"true\"\n          class=\"mt-0.5 shrink-0 text-primary\"\n        >\n          <circle cx=\"12\" cy=\"12\" r=\"10\"></circle>\n          <path d=\"M12 6v6l4 2\"></path>\n        </svg>\n        <div>\n          <p class=\"text-sm font-semibold\">Open late</p>\n          <p class=\"text-sm text-muted-foreground\">Kitchen runs until midnight, seven days.</p>\n        </div>\n      </div>\n      <div class=\"flex items-start gap-3 rounded-lg border border-border bg-card p-4\">\n        <svg\n          xmlns=\"http://www.w3.org/2000/svg\"\n          width=\"18\"\n          height=\"18\"\n          viewBox=\"0 0 24 24\"\n          fill=\"none\"\n          stroke=\"currentColor\"\n          stroke-width=\"2\"\n          stroke-linecap=\"round\"\n          stroke-linejoin=\"round\"\n          aria-hidden=\"true\"\n          class=\"mt-0.5 shrink-0 text-primary\"\n        >\n          <path\n            d=\"M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z\"\n          ></path>\n        </svg>\n        <div>\n          <p class=\"text-sm font-semibold\">Trusted local</p>\n          <p class=\"text-sm text-muted-foreground\">Fifteen years on the same corner.</p>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n",
      "type": "registry:component",
      "target": "src/components/astro-shad/sections/Hero-04.astro"
    }
  ],
  "type": "registry:component"
}